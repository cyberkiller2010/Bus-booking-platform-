<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Company Dashboard</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:system-ui;background:#1e2a3a;padding:1rem;}
        .container{max-width:1000px;margin:0 auto;}
        .card{background:white;border-radius:20px;padding:1.5rem;margin-bottom:1rem;}
        input,button,select{width:100%;padding:10px;margin:6px 0;border-radius:12px;border:1px solid #ccc;}
        button{background:#2c3e50;color:white;font-weight:bold;cursor:pointer;}
        table{width:100%;border-collapse:collapse;margin-top:1rem;}
        th,td{border:1px solid #ddd;padding:8px;text-align:left;}
        th{background:#2c3e50;color:white;}
        .bus-item{background:#f4f4f4;padding:1rem;margin-bottom:1rem;border-radius:16px;}
        .logout{background:#e67e22;}
    </style>
</head>
<body>
<div class="container">
    <div id="loginDiv" class="card">
        <h2>Company Login</h2>
        <input type="text" id="compUser" placeholder="Username">
        <input type="password" id="compPass" placeholder="Password">
        <button onclick="companyLogin()">Login</button>
        <p>Demo: user = "busco" / pass = "bus123"</p>
    </div>

    <div id="dashboardDiv" style="display:none;">
        <div class="card">
            <h2>🚌 Company Dashboard <button class="logout" onclick="logout()">Logout</button></h2>
            <hr>
            <h3>➕ Add New Bus</h3>
            <input type="text" id="newFrom" placeholder="From city">
            <input type="text" id="newTo" placeholder="To city">
            <input type="time" id="newDeparture">
            <input type="text" id="newDuration" placeholder="Duration (e.g., 5h)">
            <input type="number" id="newPrice" placeholder="Price per seat">
            <input type="number" id="newSeats" placeholder="Total seats">
            <button onclick="addBus()">Add Bus</button>
        </div>

        <div class="card">
            <h3>📋 Your Buses</h3>
            <div id="busesList"></div>
        </div>

        <div class="card">
            <h3>📖 Bookings on your buses (Passenger details)</h3>
            <table id="bookingsTable">
                <thead><tr><th>Passenger Phone</th><th>Bus</th><th>Route</th><th>Seats</th><th>Date</th><th>Unique Code</th><th>Paid</th></tr></thead>
                <tbody id="bookingsTbody"></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function initData() {
        if (!localStorage.getItem('company_buses')) {
            let defaultBuses = [
                { id: 1, company: "Royal Express", from: "Lusaka", to: "Livingstone", departure: "08:00", duration: "7h", price: 45, seats: 40, available: 40 },
                { id: 2, company: "Royal Express", from: "Lusaka", to: "Chipata", departure: "14:00", duration: "8h", price: 60, seats: 45, available: 45 }
            ];
            localStorage.setItem('company_buses', JSON.stringify(defaultBuses));
        }
        if (!localStorage.getItem('all_bookings')) {
            localStorage.setItem('all_bookings', JSON.stringify([]));
        }
    }
    initData();

    function companyLogin() {
        let u = document.getElementById('compUser').value;
        let p = document.getElementById('compPass').value;
        if (u === "busco" && p === "bus123") {
            document.getElementById('loginDiv').style.display = 'none';
            document.getElementById('dashboardDiv').style.display = 'block';
            loadCompanyBuses();
            loadCompanyBookings();
        } else { alert("Invalid credentials"); }
    }

    function loadCompanyBuses() {
        let buses = JSON.parse(localStorage.getItem('company_buses')).filter(b => b.company === "Royal Express");
        let container = document.getElementById('busesList');
        if (buses.length === 0) { container.innerHTML = "<p>No buses yet.</p>"; return; }
        let html = '';
        buses.forEach(b => {
            html += `
                <div class="bus-item">
                    <strong>${b.from} → ${b.to}</strong> | Depart: ${b.departure} | Dur: ${b.duration}<br>
                    Price: $${b.price} | Available: ${b.available}/${b.seats}<br>
                    <input type="number" id="newPrice_${b.id}" placeholder="New price" style="width:120px">
                    <input type="text" id="newDur_${b.id}" placeholder="New duration">
                    <button onclick="updateBus(${b.id})">Update</button>
                </div>
            `;
        });
        container.innerHTML = html;
    }

    function updateBus(busId) {
        let newPrice = document.getElementById(`newPrice_${busId}`).value;
        let newDur = document.getElementById(`newDur_${busId}`).value;
        let buses = JSON.parse(localStorage.getItem('company_buses'));
        let index = buses.findIndex(b => b.id === busId);
        if (newPrice) buses[index].price = parseInt(newPrice);
        if (newDur) buses[index].duration = newDur;
        localStorage.setItem('company_buses', JSON.stringify(buses));
        alert("Bus updated");
        loadCompanyBuses();
    }

    function addBus() {
        let from = document.getElementById('newFrom').value;
        let to = document.getElementById('newTo').value;
        let departure = document.getElementById('newDeparture').value;
        let duration = document.getElementById('newDuration').value;
        let price = parseInt(document.getElementById('newPrice').value);
        let seats = parseInt(document.getElementById('newSeats').value);
        if (!from || !to || !price) { alert("Fill all fields"); return; }
        let buses = JSON.parse(localStorage.getItem('company_buses'));
        let newId = Date.now();
        buses.push({
            id: newId,
            company: "Royal Express",
            from, to, departure, duration,
